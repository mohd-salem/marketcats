# AI Provider selection: claude | openai
AI_PROVIDER=claude

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# OpenAI (optional, for future use)
OPENAI_API_KEY=sk-...

# Claude model name
CLAUDE_MODEL=claude-sonnet-4-5

# OpenAI model name (optional)
OPENAI_MODEL=gpt-4o

# File upload settings
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50

# How many products to sample when generating dimension suggestions
SAMPLE_SIZE_FOR_SUGGESTIONS=30

# Products per AI batch during categorization
CATEGORIZATION_BATCH_SIZE=10
